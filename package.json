{
    "name": "butler",
    "version": "15.1.3",
    "description": "Superpowers for Qlik Sense. Task scheduling, key-value store, advanced alerting and more.",
    "scripts": {
        "build:docs": "npx jsdoc-to-markdown 'src/**/*.js' > docs/src-code-overview.md",
        "build:docker": "docker build -t butler:latest -t butler:$(node -p \"require('./package.json').version\") .",
        "build:macos": "./build-script/build-macos.sh",
        "test": "node --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --forceExit --coverage",
        "test:ci": "node --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --forceExit",
        "test:watch": "node --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --forceExit --watch --coverage",
        "test:jshint": "node_modules/jshint/bin/jshint butler.js",
        "format": "npm run format:prettier",
        "format:prettier": "npx prettier --config .prettierrc \"./**/*.{ts,css,less,js,html}\" --write",
        "butler": "node src/butler.js",
        "lint": "npx eslint src/**/*.js",
        "lint:fix": "npx eslint --fix src/**/*.js",
        "security:audit": "npm audit --audit-level=high",
        "security:full": "npm run security:audit && snyk test --severity-threshold=high",
        "sbom:generate": "rm -rf ./build && mkdir -p ./build && sbom-tool generate -b ./build -bc . -pn butler -pv $(node -p \"require('./package.json').version\") -ps \"Ptarmigan Labs\" -nsb https://sbom.ptarmiganlabs.com -V verbose",
        "deps:check": "ncu --doctor -u",
        "deps:audit": "audit-ci --config .audit-ci.json",
        "deps:lockfile": "lockfile-lint --path package-lock.json --validate-https --validate-integrity",
        "security:deps": "npm run deps:lockfile && npm run deps:audit",
        "license:check": "license-checker-rseidelsohn --onlyAllow 'MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;0BSD'",
        "license:report": "license-checker-rseidelsohn --csv --out licenses.csv",
        "license:summary": "license-checker-rseidelsohn --summary",
        "license:json": "license-checker-rseidelsohn --json --out licenses.json",
        "license:full": "npm run license:summary && npm run license:check && npm run license:report",
        "knip": "knip"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ptarmiganlabs/butler.git"
    },
    "keywords": [
        "butler",
        "senseops",
        "devops",
        "qliksense",
        "qlik sense",
        "alerts",
        "alerting",
        "incident response",
        "scheduler",
        "task chaining"
    ],
    "author": "Göran Sander",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/ptarmiganlabs/butler/issues"
    },
    "homepage": "https://github.com/ptarmiganlabs/butler",
    "files": [
        "butler.js"
    ],
    "type": "module",
    "exports": "./butler.js",
    "dependencies": {
        "@breejs/later": "^4.2.0",
        "@fastify/autoload": "^6.3.1",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/reply-from": "^12.6.2",
        "@fastify/sensible": "^6.0.4",
        "@fastify/static": "^9.1.3",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.6",
        "@influxdata/influxdb-client": "^1.35.0",
        "@influxdata/influxdb3-client": "^2.2.0",
        "@keyvhq/core": "^2.1.15",
        "@xstate/fsm": "^2.1.0",
        "ajv": "^8.20.0",
        "ajv-keywords": "^5.1.0",
        "any-base": "^1.1.0",
        "axios": "^1.16.0",
        "commander": "^14.0.3",
        "config": "^4.4.1",
        "cron-job-manager": "^2.3.1",
        "email-validator": "^2.0.4",
        "enigma.js": "^2.14.0",
        "express-handlebars": "^9.0.1",
        "fastify": "^5.8.5",
        "fastify-healthcheck": "^5.1.0",
        "fastify-plugin": "^5.1.0",
        "fs-extra": "^11.3.4",
        "handlebars": "^4.7.9",
        "http-errors": "^2.0.1",
        "i": "^0.3.7",
        "influx": "^5.12.0",
        "is-unc-path": "^1.0.0",
        "js-yaml": "^4.1.1",
        "lodash": "^4.18.1",
        "luxon": "^3.7.2",
        "mkdirp": "^3.0.1",
        "moment": "^2.30.1",
        "moment-precise-range-plugin": "^1.3.0",
        "mqtt": "^5.15.1",
        "ms-teams-wrapper": "^1.0.2",
        "nodemailer": "^8.0.7",
        "nodemailer-express-handlebars": "^7.0.0",
        "os": "^0.1.2",
        "posthog-node": "^5.33.3",
        "promise": "^8.3.0",
        "rate-limiter-flexible": "^11.0.2",
        "systeminformation": "^5.31.5",
        "upath": "^3.0.7",
        "uuid": "^14.0.0",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "ws": "^8.20.0",
        "xstate": "^5.31.0"
    },
    "devDependencies": {
        "@babel/plugin-syntax-import-assertions": "^7.28.6",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "audit-ci": "^7.1.0",
        "esbuild": "^0.28.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.6.0",
        "jest": "^30.3.0",
        "jsdoc-to-markdown": "^9.1.3",
        "knip": "^6.11.0",
        "license-checker-rseidelsohn": "^4.4.2",
        "lockfile-lint": "^5.0.0",
        "npm-check-updates": "^22.1.0",
        "prettier": "^3.8.3",
        "snyk": "^1.1304.1",
        "typescript": "^6.0.3"
    }
}
